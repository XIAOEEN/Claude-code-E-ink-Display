{
  "name": "claude-code-e-ink-display",
  "version": "1.0.0",
  "description": "E-Ink BLE Display integration for Claude Code. Send notifications and heartbeat messages to a tri-color e-ink display.",
  "main": "eink_final.py",
  "keywords": [
    "claude",
    "claude-code",
    "eink",
    "display",
    "ble",
    "bluetooth",
    "notification",
    "hardware",
    "iot"
  ],
  "author": "",
  "license": "MIT",
  "openclaw": {
    "extensions": [
      {
        "name": "eink-display",
        "version": "1.0.0",
        "description": "E-Ink BLE Display integration"
      }
    ],
    "compat": {
      "pluginApi": "1.0.0"
    },
    "build": {
      "openclawVersion": "^1.0.0"
    }
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "device_address": {
        "type": "string",
        "description": "BLE device MAC address"
      },
      "write_char_uuid": {
        "type": "string",
        "description": "BLE write characteristic UUID"
      },
      "enabled": {
        "type": "boolean",
        "description": "Enable eink functionality"
      },
      "heartbit_enabled": {
        "type": "boolean",
        "description": "Enable hourly love messages"
      },
      "heartbit_interval_minutes": {
        "type": "number",
        "description": "Interval between heartbit messages"
      }
    }
  }
}
