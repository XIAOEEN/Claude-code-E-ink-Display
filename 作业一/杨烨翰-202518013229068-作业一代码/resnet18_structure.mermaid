graph LR
    subgraph Input["输入"]
        A["图像<br/>[batch, 3, 224, 224]"]
    end

    Input --> Stem

    subgraph Stem["Stem"]
        B["Conv1: 7×7, stride=2, pad=3 → 64<br/>BN → ReLU<br/>MaxPool: 3×3, stride=2, pad=1"]
    end

    Stem --> C["[batch, 64, 56, 56]"]

    C --> Layer1

    subgraph Layer1["Layer1: 64→64"]
        L1B1["Block1<br/>conv3×3×2<br/>stride=1"]
        L1B2["Block2<br/>conv3×3×2<br/>stride=1"]
        L1B1 --> L1B2
    end

    Layer1 --> L1Out["[batch, 64, 56, 56]"]

    L1Out --> Layer2

    subgraph Layer2["Layer2: 64→128"]
        L2B1["Block1<br/>conv3×3 stride=2<br/>+ Downsample 1×1"]
        L2B2["Block2<br/>conv3×3×2<br/>stride=1"]
        L2B1 --> L2B2
    end

    Layer2 --> L2Out["[batch, 128, 28, 28]"]

    L2Out --> Layer3

    subgraph Layer3["Layer3: 128→256"]
        L3B1["Block1<br/>conv3×3 stride=2<br/>+ Downsample 1×1"]
        L3B2["Block2<br/>conv3×3×2<br/>stride=1"]
        L3B1 --> L3B2
    end

    Layer3 --> L3Out["[batch, 256, 14, 14]"]

    L3Out --> Layer4

    subgraph Layer4["Layer4: 256→512"]
        L4B1["Block1<br/>conv3×3 stride=2<br/>+ Downsample 1×1"]
        L4B2["Block2<br/>conv3×3×2<br/>stride=1"]
        L4B1 --> L4B2
    end

    Layer4 --> L4Out["[batch, 512, 7, 7]"]

    L4Out --> Head

    subgraph Head["分类头"]
        H1["AdaptiveAvgPool: 7×7→1×1<br/>Flatten → Dropout(0.5)"]
        H2["FC: 512 → 2<br/>SoftMax"]
        H1 --> H2
    end

    Head --> O["[batch, 2]<br/>P(cat), P(dog)"]

    O --> Loss

    subgraph Loss["损失函数"]
        L["CrossEntropyLoss<br/>L = -Σ y·log(p)"]
    end

    style A fill:#e1f5fe
    style O fill:#c8e6c9
    style L fill:#ffecb3
